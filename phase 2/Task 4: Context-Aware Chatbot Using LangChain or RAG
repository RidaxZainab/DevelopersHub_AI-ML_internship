    # Process new incoming user queries
    if user_query := st.chat_input("Ask a question about the project or lab rules..."):
        
        # Display human message instantly
        with st.chat_message("User"):
            st.write(user_query)
            
        # Execute chain query using historical state context array
        with st.chat_message("Assistant"):
            with st.spinner("Searching document context and generating response..."):
                response = rag_chain.invoke({
                    "input": user_query,
                    "chat_history": st.session_state.chat_history
                })
                
                answer = response["answer"]
                st.write(answer)
                
        # Append latest transaction pair into continuous memory array
        st.session_state.chat_history.extend([
            HumanMessage(content=user_query),
            AIMessage(content=answer)
        ])
